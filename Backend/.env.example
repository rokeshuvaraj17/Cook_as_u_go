PORT=5051

# Receipt scan (FastAPI / ScanAndSave). The kitchen API proxies /api/scan/receipt-preview → this URL.
SCAN_API_URL=http://127.0.0.1:8000

JWT_SECRET=replace-with-a-long-random-string-min-16-chars
BCRYPT_ROUNDS=10

# App secret mixed into passwords before bcrypt (pepper). Also accepted: salt_pepper
SALT_PEPPER=your-long-random-secret-do-not-share

# Supabase Postgres — replace [YOUR-PASSWORD] with your database password (Project Settings → Database).
# Pooler (PgBouncer) for the API runtime:
DATABASE_URL="postgresql://postgres.iwucweduyanrkbaqxicl:[YOUR-PASSWORD]@aws-1-us-west-2.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Direct connection — use for migrations / schema / purge script when possible:
DIRECT_URL="postgresql://postgres.iwucweduyanrkbaqxicl:[YOUR-PASSWORD]@aws-1-us-west-2.pooler.supabase.com:5432/postgres"
