PORT=5051

# ScanAndSave (FastAPI) base URL. Kitchen API POST /api/scan/receipt-preview proxies here.
# LLM API keys come from the user’s row in user_api_settings (mobile → API settings), not from ScanAndSave/.env.
#
# Local dev:
SCAN_API_URL=http://127.0.0.1:8000
#
# Render / production (required): public https origin of ScanAndSave (FastAPI). Without this, receipt scan from mobile fails.
# Example (this repo’s services):
# SCAN_API_URL=https://cook-as-u-go-scan.onrender.com

JWT_SECRET=replace-with-a-long-random-string-min-16-chars
BCRYPT_ROUNDS=10

# App secret mixed into passwords before bcrypt (pepper). Also accepted: salt_pepper
SALT_PEPPER=your-long-random-secret-do-not-share

# Separate secret for encrypting user LLM API keys at rest (AES-256-GCM). Also: salt_pepper_api_key_salt
# Required if users save API keys. Min 16 characters; keep stable or existing ciphertext becomes unreadable.
SALT_PEPPER_API_KEY_SALT=another-long-random-secret-different-from-SALT_PEPPER

# Supabase Postgres — replace [YOUR-PASSWORD] with your database password (Project Settings → Database).
# Pooler (PgBouncer) for the API runtime:
DATABASE_URL="postgresql://postgres.iwucweduyanrkbaqxicl:[YOUR-PASSWORD]@aws-1-us-west-2.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Direct connection — use for migrations / schema / purge script when possible:
DIRECT_URL="postgresql://postgres.iwucweduyanrkbaqxicl:[YOUR-PASSWORD]@aws-1-us-west-2.pooler.supabase.com:5432/postgres"
