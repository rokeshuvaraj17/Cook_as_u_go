# Copy to upload-keystore.properties in this folder (same directory as upload-keystore.jks).
# File name must be: credentials/upload-keystore.properties
# Paths in storeFile are relative to the android/ folder.
#
#   cp credentials/upload-keystore.properties.example credentials/upload-keystore.properties
#   nano credentials/upload-keystore.properties
#
# Discover key alias:
#   keytool -list -keystore credentials/upload-keystore.jks

storePassword=YOUR_KEYSTORE_PASSWORD
keyPassword=YOUR_KEY_PASSWORD
keyAlias=YOUR_KEY_ALIAS
storeFile=../credentials/upload-keystore.jks
