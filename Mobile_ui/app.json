{
  "expo": {
    "name": "Cook As U Go",
    "slug": "cook-as-u-go",
    "version": "1.0.7",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "ios": {
      "supportsTablet": true,
      "buildNumber": "8",
      "bundleIdentifier": "com.mrrokeshcookasugo.mobileapp"
    },
    "android": {
      "package": "com.mr_rokeshcookasugo.mobileapp",
      "versionCode": 11,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#000000"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "apiUrl": "",
      "eas": {
        "projectId": "1d49a4c2-f8f2-40ec-b046-8f9faadf325e"
      }
    },
    "plugins": [
      "./plugins/withUploadKeystoreSigning.js",
      [
        "expo-build-properties",
        {
          "android": {
            "compileSdkVersion": 35,
            "targetSdkVersion": 35,
            "minSdkVersion": 24,
            "usesCleartextTraffic": true
          }
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow access to photos to add receipt images to your pantry.",
          "cameraPermission": "Allow camera to photograph grocery receipts."
        }
      ],
      "@react-native-community/datetimepicker",
      "expo-font"
    ],
    "owner": "rokeshuvaraj"
  }
}
