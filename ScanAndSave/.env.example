# Copy to `.env` in this folder (ScanAndSave/). Never commit `.env`.
#
# Render: set Root Directory to `ScanAndSave`, build `pip install -r requirements.txt`,
# start `bash render-start.sh` (script sets PYTHONPATH to monorepo root). Or leave Root
# Directory empty and start `bash ScanAndSave/render-start.sh` from repo root.
#
# LLM API keys are stored per user in the kitchen app database (API settings).
# The mobile app sends receipt images to the kitchen API, which proxies to this
# service and passes X-LLM-Api-Key from the database. Do not put user keys here.
#
# Optional dev-only fallback (not used in normal app flow):
# OPENROUTER_API_KEY=

# Default model when the request does not pass X-LLM-Model (e.g. local curl tests).
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_FALLBACK_MODEL=google/gemma-3-4b-it:free
OPENROUTER_MAX_TOKENS=800
# OPENROUTER_HTTP_REFERER=https://your-site.example
# OPENROUTER_APP_TITLE=Cook As You Go

# SQLite for local ScanAndSave DB (receipt pipeline)
DATABASE_URL=sqlite:///./grocery.db
